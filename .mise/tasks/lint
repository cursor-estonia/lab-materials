#!/usr/bin/env bash
#MISE description="Check markdown lint and TOC"
set -euo pipefail

markdownlint-cli2 "**/*.md"

fail=0
for f in *.md; do
  if ! grep -q '<!-- toc -->' "$f"; then
    continue
  fi

  expected=$(markdown-toc --maxdepth 2 --bullets "-" "$f")
  actual=$(sed -n '/<!-- toc -->/,/<!-- tocstop -->/p' "$f" | sed '1d;$d' | sed '/^$/d')
  expected_trimmed=$(echo "$expected" | sed '/^$/d')

  if [ "$expected_trimmed" != "$actual" ]; then
    echo "TOC outdated: $f"
    fail=1
  fi
done

exit $fail
